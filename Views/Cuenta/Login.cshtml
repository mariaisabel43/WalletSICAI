@using WalletSICAI.viewModels
@model LoginViewModel

@{
    ViewData["Title"] = "Inicio de Sesión";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Inicio de Sesión</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">

    <!-- CSS propio -->
    <link href="~/css/site.css" rel="stylesheet" />
</head>

<body class="login-bg">

    @if (TempData["Exito"] != null)
    {
        <div class="position-fixed top-0 end-0 p-3" style="z-index: 9999;">
            <div id="toastExito" class="toast align-items-center text-bg-success border-0 show" role="alert">
                <div class="d-flex">
                    <div class="toast-body">
                        <i class="fa-solid fa-circle-check me-2"></i>
                        @TempData["Exito"]
                    </div>
                </div>
            </div>
        </div>

        <script>
                setTimeout(function () {
                    var toast = document.getElementById('toastExito');
                    if (toast) {
                        toast.classList.remove('show');
                    }
                }, 3000);
        </script>
    }

    @if (TempData["Error"] != null)
    {
        <div class="position-fixed top-0 end-0 p-3" style="z-index: 9999;">
            <div id="toastError" class="toast align-items-center text-bg-danger border-0 show" role="alert">
                <div class="d-flex">
                    <div class="toast-body">
                        <i class="fa-solid fa-circle-xmark me-2"></i>
                        @TempData["Error"]
                    </div>
                </div>
            </div>
        </div>

        <script>
                setTimeout(function () {
                    var toast = document.getElementById('toastError');
                    if (toast) {
                        toast.classList.remove('show');
                    }
                }, 3000);
        </script>
    }

    <div class="login-container">
        <div class="login-card">
            <h3 class="login-title">Inicio de Sesión</h3>
            <p class="login-subtitle">Bienvenido de nuevo a Wallet SICAI.</p>

            <form asp-action="Login" method="post">

                <!-- Email -->
                <div class="mb-3">
                    <label class="form-label">Correo electrónico</label>
                    <div class="input-group login-input">
                        <span class="input-group-text">
                            <i class="fa-solid fa-envelope"></i>
                        </span>
                        <input asp-for="AdministrativoEmail"
                               class="form-control"
                               placeholder="ejemplo@eduwallet.com" />
                    </div>
                    <span asp-validation-for="AdministrativoEmail" class="text-danger small"></span>
                </div>

                <!-- Password -->
                <div class="mb-2">
                    <label class="form-label">Contraseña</label>

                    <div class="input-group login-input">
                        <span class="input-group-text">
                            <i class="fa-solid fa-lock"></i>
                        </span>

                        <input asp-for="AdministrativoPassword"
                               type="password"
                               class="form-control"
                               id="passwordInput"
                               placeholder="••••••••" />

                        <span class="input-group-text password-toggle"
                              onclick="togglePassword()">
                            <i class="fa-solid fa-eye" id="eyeIcon"></i>
                        </span>
                    </div>
                    
                    <span asp-validation-for="AdministrativoPassword"
                          class="text-danger small"></span>
                </div>

                <!-- Remember + Forgot -->
                <div class="d-flex justify-content-between align-items-center mb-3">

                    @* <!-- Remember Me -->
                    <div class="form-check d-flex align-items-center m-0">
                        <input asp-for="RememberMe" class="form-check-input me-2" />
                        <label class="form-check-label mb-0">
                            @Html.DisplayNameFor(m => m.RememberMe)
                        </label>
                    </div>
 *@
                    <!-- Forgot -->
                    @* <a href="#" class="forgot-link">¿Olvidó su contraseña?</a> *@
                    <a href="#" class="forgot-link" data-bs-toggle="modal" data-bs-target="#resetPasswordModal">
                        ¿Olvidó su contraseña?
                    </a>
                </div>


                <!-- Button -->
                <button type="submit" class="btn login-btn w-100">
                    Iniciar Sesión
                </button>

                @* @if (!ViewData.ModelState.IsValid)
                {
                    <div class="text-danger text-center mt-3">
                        Credenciales inválidas
                    </div>
                } *@
            </form>
        </div>
    </div>

    <!-- JS para mostrar / ocultar contraseña -->
    <script>
        function togglePassword() {
            const passwordInput = document.getElementById("passwordInput");
            const eyeIcon = document.getElementById("eyeIcon");

            if (passwordInput.type === "password") {
                passwordInput.type = "text";
                eyeIcon.classList.remove("fa-eye");
                eyeIcon.classList.add("fa-eye-slash");
            } else {
                passwordInput.type = "password";
                eyeIcon.classList.remove("fa-eye-slash");
                eyeIcon.classList.add("fa-eye");
            }
        }
    </script>

    <!-- Modal error credenciales -->

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="modal fade" id="loginErrorModal" tabindex="-1" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content login-error-modal">

                    <div class="modal-body text-center p-4">
                        <i class="fa-solid fa-circle-xmark mb-3"></i>

                        <h5 class="text-white mb-2">Error de autenticación</h5>

                        <p class="mb-4">
                            El correo electrónico o la contraseña son incorrectos.
                            Por favor, verifique sus datos e intente nuevamente.
                        </p>

                        <button type="button"
                            class="btn btn-outline-light px-4"
                            data-bs-dismiss="modal">
                            Entendido
                        </button>
                    </div>

                </div>
            </div>
        </div>
    }

    @if (!ViewData.ModelState.IsValid)
    {
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                const modal = new bootstrap.Modal(
                    document.getElementById('loginErrorModal')
                );
                modal.show();
            });
        </script>
    }

     <!-- Modal recuperar contraseña -->
    <div class="modal fade" id="resetPasswordModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content reset-modal">

                <div class="modal-header border-0">
                    <h5 class="modal-title text-white">
                        <i class="fa-solid fa-key me-2 text-warning"></i>
                        Restablecer contraseña
                    </h5>
                    <button type="button"
                            class="btn-close btn-close-white"
                            data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <p class="text-light small mb-4">
                        Ingresa el correo registrado y te enviaremos un correo para restablecer tu contraseña.
                    </p>

                    <form id="forgotPasswordForm">
                        <div class="mb-3">
                            <label class="form-label text-light">Correo electrónico</label>
                            <input type="email" name="email" class="form-control reset-input" required />
                        </div>
                        <button type="submit" class="btn btn-primary reset-btn w-100">
                            Enviar correo de reset
                        </button>
                    </form>
                </div>

            </div>
        </div>
    </div> 

    <!-- Modal de envio éxitoso -->
    <div class="modal fade" id="successModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content login-error-modal">
                <div class="modal-body text-center p-4">
                    <i class="fa-solid fa-circle-check mb-3 text-success"></i>
                    <h5 class="text-white mb-2">Solicitud procesada</h5>
                    <p class="mb-4">
                        Si el correo está registrado, se enviará un enlace de reset.
                    </p>
                    <button type="button"
                            class="btn btn-outline-light px-4"
                            onclick="closeAllModals()">
                        Entendido
                    </button>

                </div>
            </div>
        </div>
    </div>

    <!-- Modal de envio error -->
    <div class="modal fade" id="errorModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content login-error-modal">
                <div class="modal-body text-center p-4">
                    <i class="fa-solid fa-circle-xmark mb-3 text-danger"></i>
                    <h5 class="text-white mb-2">Error</h5>
                    <p class="mb-4">
                        Error al procesar la solicitud. Intente nuevamente.
                    </p>
                    <button type="button" class="btn btn-outline-light px-4" data-bs-dismiss="modal">
                        Cerrar
                    </button>
                </div>
            </div>
        </div>
    </div>

    

    <!-- JS para mostrar / ocultar contraseña -->
    <script>
        
    
        document.getElementById("forgotPasswordForm").addEventListener("submit", async function (e) {
            e.preventDefault();

            const formData = new FormData(this);

            const response = await fetch("/forgot-password", {
                method: "POST",
                body: formData
            });

            if (response.ok) {
                // const successModal = new bootstrap.Modal(document.getElementById('successModal'));
                // successModal.show();
                const successModalEl = document.getElementById('successModal');
                const successModal = new bootstrap.Modal(successModalEl);
                successModal.show();

                // Cuando el usuario haga clic en "Entendido", cerramos ambos modales
                successModalEl.querySelector("button[onclick='closeAllModals()']")
                    ?.addEventListener("click", function () {
                        // Cerrar modal de éxito
                        const successInstance = bootstrap.Modal.getInstance(successModalEl);
                        if (successInstance) successInstance.hide();

                        // Cerrar modal de recuperación
                        const resetModalEl = document.getElementById('resetPasswordModal');
                        const resetInstance = bootstrap.Modal.getInstance(resetModalEl);
                        if (resetInstance) resetInstance.hide();

                        // Resetear el formulario dentro del modal de recuperación
                        const resetForm = document.getElementById('forgotPasswordForm');
                        if (resetForm) resetForm.reset();

                    });


            } else {
                const errorModal = new bootstrap.Modal(document.getElementById('errorModal'));
                errorModal.show();
            }

        });
    </script>



    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
