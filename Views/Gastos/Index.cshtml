@using WalletSICAI.viewModels
@model GastoViewModel

@{
    ViewData["Title"] = "Gestión de Gastos y Categorías";
    Layout = null;
}

@{
    var activeTab = Context.Request.Query["tab"].ToString();
}

<!DOCTYPE html>

<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Registrar Gasto</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- FontAwesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />

    <!-- CSS propio -->
    <link href="~/css/site.css" rel="stylesheet" />
    

</head>

<body class="admin-body">

    <div class="d-flex min-vh-100">

        <!-- SIDEBAR -->

        <nav class="admin-sidebar">

            <h4 class="sidebar-title">Wallet SICAI</h4>

            <ul class="nav flex-column sidebar-nav">

                <li class="nav-item">
                    <a class="nav-link" asp-controller="Home" asp-action="Index">
                        <i class="fa-solid fa-house"></i> Menú Principal
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" asp-controller="DatosEstudiantes" asp-action="Buscar">
                        <i class="fa-solid fa-magnifying-glass"></i> Consulta de Saldo
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" asp-controller="RecargarSaldo" asp-action="Recargar">
                        <i class="fa-solid fa-wallet"></i> Recargar Saldo
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" asp-controller="Historial" asp-action="BuscarEstudiante">
                        <i class="fa-solid fa-clock-rotate-left"></i> Historial Recargas Estudiante
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" asp-controller="Reportes" asp-action="FormularioReportes">
                        <i class="fa-solid fa-file-pdf"></i> Reportes Historial Recargas
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" asp-controller="Gastos" asp-action="Buscar">
                        <i class="fa-solid fa-sack-dollar"></i> Historial Gastos
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link active" asp-controller="Gastos" asp-action="Index">
                        <i class="fa-solid fa-tag"></i> Gestión de Gastos
                    </a>
                </li>

            </ul>

            <div class="sidebar-bottom">
                <a class="nav-link logout" asp-controller="Cuenta" asp-action="Logout">
                    <i class="fa-solid fa-right-from-bracket"></i> Log Out
                </a>
            </div>

        </nav>

        <!-- CONTENIDO -->

        <main class="admin-main gastos-page flex-grow-1 p-5">


            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="text-white mb-4">Gestión de Gastos de Estudiantes y Categorías</h2>

                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-light">
                    Volver al menú
                </a>

            </div>

            <!-- TABS -->

            <ul class="nav nav-tabs" id="gestionTabs" role="tablist">

                <li class="nav-item" role="presentation">
                    <button class="nav-link @(activeTab == "gasto" || string.IsNullOrEmpty(activeTab) ? "active" : "")"
                            id="gasto-tab"
                            data-bs-toggle="tab"
                            data-bs-target="#gasto"
                            type="button"
                            role="tab">
                        Registrar Gasto
                    </button>
                </li>

                <li class="nav-item" role="presentation">
                    <button class="nav-link @(activeTab == "tipo" ? "active" : "")"
                            id="tipo-tab"
                            data-bs-toggle="tab"
                            data-bs-target="#tipo"
                            type="button"
                            role="tab">
                        Registrar Tipo de Gasto
                    </button>
                </li>

            </ul>

            <div class="tab-content mt-3" id="gestionTabsContent">

                <div class="tab-pane fade @(activeTab == "gasto" || string.IsNullOrEmpty(activeTab) ? "show active" : "")"
                     id="gasto"
                     role="tabpanel"
                     aria-labelledby="gasto-tab">

                    @await Html.PartialAsync("~/Views/Gastos/CrearGasto.cshtml", Model)

                </div>

                <div class="tab-pane fade @(activeTab == "tipo" ? "show active" : "")"
                     id="tipo"
                     role="tabpanel"
                     aria-labelledby="tipo-tab">

                    @await Html.PartialAsync("~/Views/TiposGastos/CrearTipoGasto.cshtml", Model.TiposGastoVM)

                </div>

            </div>

            @*  <ul class="nav nav-tabs" id="gestionTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="gasto-tab" data-bs-toggle="tab" data-bs-target="#gasto" type="button" role="tab">
                Registrar Gasto
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="tipo-tab" data-bs-toggle="tab" data-bs-target="#tipo" type="button" role="tab">
                Registrar Tipo de Gasto
            </button>
        </li>
    </ul>

    <div class="tab-content mt-3" id="gestionTabsContent">
        <!-- TAB: Registrar Gasto -->
        <div class="tab-pane fade show active" id="gasto" role="tabpanel" aria-labelledby="gasto-tab">
            @await Html.PartialAsync("~/Views/Gastos/CrearGasto.cshtml", Model)
        </div>

        <!-- TAB: Registrar Tipo de Gasto -->
        <div class="tab-pane fade" id="tipo" role="tabpanel" aria-labelledby="tipo-tab">
            @await Html.PartialAsync("~/Views/TiposGastos/CrearTipoGasto.cshtml", Model.TiposGastoVM)
        </div>
    </div> *@

            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

        </main>

    </div>

</body>

</html>

