@model WalletSICAI.Models.Estudiante

@{
    ViewData["Title"] = "Historial de Gastos";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Historial de Gastos</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Font Awesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />

    <!-- CSS propio -->
    <link href="~/css/site.css" rel="stylesheet" />
</head>
<body class="admin-body">

    <div class="d-flex">

        <!-- ================= SIDEBAR ================= -->
        <nav class="admin-sidebar">
            <h4 class="sidebar-title">Wallet SICAI</h4>

            <ul class="nav flex-column sidebar-nav">
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Home" asp-action="Index">
                        <i class="fa-solid fa-house"></i> Menú Principal
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" asp-controller="DatosEstudiantes" asp-action="Buscar">
                        <i class="fa-solid fa-magnifying-glass"></i> Consulta de Saldo
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" asp-controller="RecargarSaldo" asp-action="Recargar">
                        <i class="fa-solid fa-wallet"></i> Recargar Saldo
                    </a>
                </li>


                <li class="nav-item">
                    <a class="nav-link" asp-controller="Historial" asp-action="BuscarEstudiante">
                        <i class="fa-solid fa-clock-rotate-left"></i> Historial Recargas Estudiante
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" asp-controller="Reportes" asp-action="FormularioReportes">
                        <i class="fa-solid fa-file-pdf"></i> Reportes Historial Recargas
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link active" asp-controller="Gastos" asp-action="Buscar">
                        <i class="fa-solid fa-sack-dollar"></i> Historial Gastos
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" asp-controller="Gastos" asp-action="Index">
                        <i class="fa-solid fa-tag"></i> Gestión de Gastos
                    </a>
                </li>
            </ul>

            <div class="sidebar-bottom">
                <a class="nav-link logout" asp-controller="Cuenta" asp-action="Logout">
                    <i class="fa-solid fa-right-from-bracket"></i> Log Out
                </a>
            </div>
        </nav>

        <!-- ================= CONTENIDO ================= -->
        <main class="admin-main flex-grow-1 p-5">

            <!-- HEADER -->
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="text-white mb-0">
                    Historial de gastos – @Model.EstudianteNombreCompleto
                </h2>

                <a asp-controller="Gastos" asp-action="Buscar" class="btn btn-outline-light">
                    <i class="fa-solid fa-arrow-left me-2"></i> Volver
                </a>
            </div>
            <!-- CARD HISTORIAL -->
            <div class="results-card">

                <h5 class="text-white mb-3">
                    <i class="fa-solid fa-list me-2"></i> Detalle de gastos
                </h5>

                @if (Model.GastosEstudiantes != null && Model.GastosEstudiantes.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-dark table-hover align-middle">
                            <thead>
                                <tr>
                                    <th>Fecha</th>
                                    <th>Categoría</th>
                                    <th>Descripción</th>
                                    <th>Estado</th>
                                    <th>Monto</th>
                                    <th>Acción</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var gasto in Model.GastosEstudiantes)
                                {
                                    <tr>
                                        <td>@gasto.FechaGasto</td>
                                        <td>@gasto.TipoGastos?.Categoria</td>
                                        <td>@gasto.Descripcion</td>
                                        <td>
                                            
                                            @if (gasto.EsDevuelto)
                                            {
                                                <span class="badge bg-success ms-2">DEVUELTO</span>
                                            }
                                            else if (gasto.MontoGasto < 0)
                                            {
                                                <span class="badge bg-info ms-2">DEVOLUCIÓN</span>
                                            }
                                        </td>
                                        <td>
                                            @if (gasto.MontoGasto < 0)
                                            {
                                                <span class="text-success">@gasto.MontoGasto</span>
                                            }
                                            else
                                            {
                                                <span>@gasto.MontoGasto</span>
                                            }
                                        </td>
                                        <td>
                                            @if (!gasto.EsDevuelto && gasto.MontoGasto > 0)
                                            {
                                                <form asp-action="DevolverGasto" method="post" class="d-inline">
                                                    <input type="hidden" name="id" value="@gasto.GastoId" />
                                                    <button type="submit" class="btn btn-warning btn-sm">
                                                        <i class="fa-solid fa-rotate-left me-1"></i> Devolver
                                                    </button>
                                                </form>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="alert alert-secondary bg-dark text-light border-0">
                        <i class="fa-solid fa-circle-info me-2"></i>
                        Este estudiante no tiene gastos registrados.
                    </div>
                }

            </div>

        </main>
    </div>

</body>
</html>
