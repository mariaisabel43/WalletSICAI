@using WalletSICAI.viewModels
@model GastoViewModel

@{
    ViewData["Title"] = "Registrar Gasto";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Registrar Gasto</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- FontAwesome -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />

    <!-- CSS propio -->
    <link href="~/css/site.css" rel="stylesheet" />
</head>

<body class="admin-body">

    <div class="d-flex min-vh-100">

        <!-- CONTENIDO -->
        <main class="admin-main gastos-page flex-grow-1 p-5">

            <!-- ENCABEZADO -->
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2 class="text-white mb-0">
                    Registrar Gasto a Estudiante
                </h2>
            </div>

            <!-- CARD -->
            <div class="recarga-container text-white p-4 rounded-4 mx-auto" style="max-width:720px;">

                @if (TempData["Exito"] != null)
                {
                    <div class="position-fixed top-0 end-0 p-3" style="z-index: 9999;">
                        <div id="toastExito" class="toast align-items-center text-bg-success border-0 show" role="alert">
                            <div class="d-flex">
                                <div class="toast-body">
                                    <i class="fa-solid fa-circle-check me-2"></i>
                                    @TempData["Exito"]
                                </div>
                            </div>
                        </div>
                    </div>

                    <script>
                            setTimeout(function () {
                                var toast = document.getElementById('toastExito');
                                    if (toast) {
                                        toast.classList.remove('show');
                                    }
                            }, 3000);
                    </script>
                }

                @if (TempData["Error"] != null)
                {
                    <div class="position-fixed top-0 end-0 p-3" style="z-index: 9999;">
                        <div id="toastError" class="toast align-items-center text-bg-danger border-0 show" role="alert">
                            <div class="d-flex">
                                <div class="toast-body">
                                    <i class="fa-solid fa-circle-xmark me-2"></i>
                                    @TempData["Error"]
                                </div>
                            </div>
                        </div>
                    </div>

                    <script>
                             setTimeout(function () {
                                var toast = document.getElementById('toastError');
                                    if (toast) {
                                        toast.classList.remove('show');
                                    }
                             }, 3000);
                    </script>
                }

                <form id="gastoForm" asp-action="CrearGasto" method="post">

                    <!-- DATOS ESTUDIANTE -->
                    <h5 class="mb-3 text-primary">
                        <i class="fa-solid fa-user-graduate me-2"></i> Datos del estudiante
                    </h5>

                    <div class="mb-3">
                        <label asp-for="EstudianteCedula" class="form-label"></label>
                        <input asp-for="EstudianteCedula" class="form-control text-white border-0" />
                        <span asp-validation-for="EstudianteCedula" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="EstudianteNombreCompleto" class="form-label"></label>
                        <input asp-for="EstudianteNombreCompleto" class="form-control text-white border-0" />
                        <span asp-validation-for="EstudianteNombreCompleto" class="text-danger"></span>
                    </div>

                    <!-- DATOS GASTO -->
                    <h5 class="mb-3 text-primary">
                        <i class="fa-solid fa-coins me-2"></i> Detalles del gasto
                    </h5>

                    <div class="mb-3">
                        <label asp-for="TipoGastoId" class="form-label"></label>
                        <select asp-for="TipoGastoId" class="form-select text-white border-0" id="tipoGastoSelect">
                            <option value="">Seleccione un tipo</option>

                            @foreach (var item in Model.TiposGasto)
                            {
                                <option value="@item.TipoGastoId" data-precio="@item.Precio">
                                    @item.Categoria
                                </option>
                            }

                        </select>
                        <span asp-validation-for="TipoGastoId" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="MontoGasto" class="form-label"></label>
                        <input asp-for="MontoGasto" class="form-control text-white border-0" id="montoInput" readonly />
                        <span asp-validation-for="MontoGasto" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Descripcion" class="form-label"></label>
                        <input asp-for="Descripcion" class="form-control text-white border-0" />
                        <span asp-validation-for="Descripcion" class="text-danger"></span>
                    </div>

                    <!-- BOTONES -->
                    <div class="mt-4 d-grid gap-2">

                        <button type="button"
                                class="btn btn-primary w-100 mb-2"
                                data-bs-toggle="modal"
                                data-bs-target="#confirmarGastoModal">
                            <i class="fa-solid fa-receipt me-2"></i> Registrar gasto
                        </button>

                        <button type="button"
                                class="btn btn-danger"
                                data-bs-toggle="modal"
                                data-bs-target="#cancelarGastoModal">
                            <i class="fa-solid fa-xmark me-2"></i> Cancelar
                        </button>

                    </div>

                </form>

            </div>

            <!-- MODAL CONFIRMAR GASTO -->
            <div class="modal fade" id="confirmarGastoModal" tabindex="-1">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content bg-dark text-white border-0 rounded-4">

                        <div class="modal-header border-0">
                            <h5 class="modal-title text-primary">
                                <i class="fa-solid fa-circle-check me-2"></i>
                                Confirmar gasto
                            </h5>
                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                        </div>

                        <div class="modal-body text-center">
                            <p class="mb-0">
                                ¿Está seguro que desea registrar este gasto?
                            </p>
                            <small class="text-secondary">
                                Se guardará la información en el sistema.
                            </small>
                        </div>

                        <div class="modal-footer border-0 justify-content-center gap-3">

                            <button type="button"
                                    class="btn btn-primary px-4"
                                    onclick="confirmarGasto()">
                                Sí, registrar
                            </button>

                            <button type="button"
                                    class="btn btn-outline-light px-4"
                                    data-bs-dismiss="modal">
                                No
                            </button>

                        </div>

                    </div>
                </div>
            </div>

            <!-- MODAL CANCELAR -->
            <div class="modal fade" id="cancelarGastoModal" tabindex="-1">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content bg-dark text-white border-0 rounded-4">

                        <div class="modal-header border-0">
                            <h5 class="modal-title text-danger">
                                <i class="fa-solid fa-triangle-exclamation me-2"></i>
                                Confirmar cancelación
                            </h5>
                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                        </div>

                        <div class="modal-body text-center">
                            <p class="mb-0">
                                ¿Está seguro que desea cancelar este registro?
                            </p>
                            <small class="text-secondary">
                                Se eliminarán todos los datos ingresados.
                            </small>
                        </div>

                        <div class="modal-footer border-0 justify-content-center">

                            <button type="button"
                                    class="btn btn-danger px-4"
                                    data-bs-dismiss="modal"
                                    onclick="cancelarGasto()">
                                Sí, cancelar
                            </button>

                            <button type="button"
                                    class="btn btn-secondary px-4"
                                    data-bs-dismiss="modal">
                                No
                            </button>

                        </div>

                    </div>
                </div>
            </div>

        </main>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <script>

        function confirmarGasto() {

            var form = document.getElementById("gastoForm");

            var modal = bootstrap.Modal.getInstance(document.getElementById('confirmarGastoModal'));
            modal.hide();

            form.submit();
        }

        function cancelarGasto() {

        document.getElementById("gastoForm").reset();

        }



         // Para el precio 
        document.getElementById("tipoGastoSelect").addEventListener("change", function () {

        var precio = this.options[this.selectedIndex].getAttribute("data-precio");

        if (precio) {
        document.getElementById("montoInput").value = precio;
        }

        });

    </script>

    @await Html.PartialAsync("_ValidationScriptsPartial")

</body>
</html>
