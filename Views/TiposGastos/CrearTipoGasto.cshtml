@model WalletSICAI.Models_.TiposGasto

@{
    ViewData["Title"] = "Registrar Tipo de Gasto";
    Layout = null;
}

<!DOCTYPE html>

<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Registrar Tipo de Gasto</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" />

</head>

<body class="admin-body">

    <div class="d-flex min-vh-100">

        <!-- SIDEBAR -->

        <nav class="admin-sidebar">

            <h4 class="sidebar-title">Wallet SICAI</h4>

            <ul class="nav flex-column sidebar-nav">

                <li class="nav-item">
                    <a class="nav-link" asp-controller="Home" asp-action="Index">
                        <i class="fa-solid fa-house"></i> Menú Principal
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" asp-controller="DatosEstudiantes" asp-action="Buscar">
                        <i class="fa-solid fa-magnifying-glass"></i> Consulta de Saldo
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" asp-controller="RecargarSaldo" asp-action="Recargar">
                        <i class="fa-solid fa-wallet"></i> Recargar Saldo
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" asp-controller="Historial" asp-action="BuscarEstudiante">
                        <i class="fa-solid fa-clock-rotate-left"></i> Historial Recargas Estudiante
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" asp-controller="Reportes" asp-action="FormularioReportes">
                        <i class="fa-solid fa-file-pdf"></i> Reportes Historial Recargas
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" asp-controller="Gastos" asp-action="Buscar">
                        <i class="fa-solid fa-sack-dollar"></i> Historial Gastos
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link active" asp-controller="TiposGastos" asp-action="CrearTipoGasto">
                        <i class="fa-solid fa-tags"></i> Crear Tipo de Gasto
                    </a>
                </li>

            </ul>

            <div class="sidebar-bottom">
                <a class="nav-link logout" asp-controller="Cuenta" asp-action="Logout">
                    <i class="fa-solid fa-right-from-bracket"></i> Log Out
                </a>
            </div>

        </nav>

        <!-- CONTENIDO -->

        <main class="admin-main gastos-page flex-grow-1 p-5">

            <div class="d-flex justify-content-between align-items-center mb-4">

                <h2 class="text-white mb-0">
                    <i class="fa-solid fa-tags me-2"></i>
                    Registrar Tipo de Gasto
                </h2>

                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-light">
                    <i class="fa-solid fa-arrow-left me-2"></i> Volver al menú
                </a>

            </div>

            <!-- TAB CONTENT -->

            <div class="tab-content mt-3" id="gestionTabsContent">

                <div class="tab-pane fade show active" id="tipo" role="tabpanel" aria-labelledby="tipo-tab">

                    <!-- CARD -->

                    <div class="recarga-container text-white p-4 rounded-4 mx-auto" style="max-width:600px;">

                        <form asp-controller="TiposGastos" asp-action="CrearTipoGasto" method="post">

                            @Html.AntiForgeryToken()

                            <div class="mb-3">
                                <label asp-for="Categoria" class="form-label">Nombre del Tipo de Gasto</label>
                                <input asp-for="Categoria" class="form-control text-white border-0" />
                                <span asp-validation-for="Categoria" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Precio" class="form-label">Precio</label>
                                <input asp-for="Precio" type="number" class="form-control text-white border-0" />
                                <span asp-validation-for="Precio" class="text-danger"></span>
                            </div>

                            <div class="mt-4 d-grid gap-2">

                                <input type="submit" value="Registrar Tipo de Gasto" class="btn btn-success" />

                            </div>

                        </form>

                    </div>

                </div>

            </div>

        </main>

    </div>

    @section Scripts {
        @{
            await Html.RenderPartialAsync("_ValidationScriptsPartial");
        }
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>