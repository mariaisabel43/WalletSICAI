

            @model WalletSICAI.viewModels.TiposGastoViewModel

@{
    ViewData["Title"] = "Gestión de Tipos de Gasto";
    Layout = null;
}

<div class="container mt-5">

    @if (TempData["Exito"] != null)
    {
        <div class="position-fixed top-0 end-0 p-3" style="z-index: 9999;">
            <div id="toastExito" class="toast align-items-center text-bg-success border-0 show" role="alert">
                <div class="d-flex">
                    <div class="toast-body">
                        <i class="fa-solid fa-circle-check me-2"></i>
                        @TempData["Exito"]
                    </div>
                </div>
            </div>
        </div>

        <script>
            setTimeout(function () {
                var toast = document.getElementById('toastExito');
                    if (toast) {
                        toast.classList.remove('show');
                    }
            }, 3000);
        </script>
    }

    @if (TempData["Error"] != null)
    {
        <div class="position-fixed top-0 end-0 p-3" style="z-index: 9999;">
            <div id="toastError" class="toast align-items-center text-bg-danger border-0 show" role="alert">
                <div class="d-flex">
                    <div class="toast-body">
                        <i class="fa-solid fa-circle-xmark me-2"></i>
                        @TempData["Error"]
                    </div>
                </div>
            </div>
        </div>

        <script>
            setTimeout(function () {
               var toast = document.getElementById('toastError');
                   if (toast) {
                       toast.classList.remove('show');
                   }
            }, 3000);
        </script>
    }
    <!-- Formulario de creación -->
    <h2 class="text-white mb-4">Registrar Tipo de Gasto</h2>
    <div class="recarga-container text-white p-4 rounded-4 mx-auto" style="max-width:600px;">
        <form asp-controller="TiposGastos" asp-action="CrearTipoGasto" method="post">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label asp-for="NuevoTipo.Categoria" class="form-label">Nombre</label>
                <input asp-for="NuevoTipo.Categoria" class="form-control text-white border-0" />
                <span asp-validation-for="NuevoTipo.Categoria" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="NuevoTipo.Precio" class="form-label">Precio</label>
                <input asp-for="NuevoTipo.Precio" type="number" class="form-control text-white border-0" />
                <span asp-validation-for="NuevoTipo.Precio" class="text-danger"></span>
            </div>


            <div class="mt-4 d-grid gap-2">

                <button type="button"
                        class="btn btn-primary w-100 mb-2"
                        data-bs-toggle="modal"
                        data-bs-target="#confirmarTipoGastoModal">
                    <i class="fa-solid fa-receipt me-2"></i> Registrar Tipo de Gasto
                </button>

                <button type="button"
                        class="btn btn-danger"
                        data-bs-toggle="modal"
                        data-bs-target="#cancelarTipoGastoModal">
                    <i class="fa-solid fa-xmark me-2"></i> Cancelar
                </button>

            </div>
        </form>
    </div>

    <!-- Modal de confirmar -->
    <div class="modal fade" id="confirmarTipoGastoModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content bg-dark text-white border-0 rounded-4">

                <div class="modal-header border-0">
                    <h5 class="modal-title text-primary">
                        <i class="fa-solid fa-circle-check me-2"></i>
                        Confirmar registro
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body text-center">
                    <p class="mb-0">¿Desea registrar este tipo de gasto?</p>
                    <small class="text-secondary">Se guardará en el sistema.</small>
                </div>

                <div class="modal-footer border-0 justify-content-center gap-3">
                    <button type="button" class="btn btn-primary px-4" onclick="confirmarTipoGasto()">
                        Sí, registrar
                    </button>

                    <button type="button" class="btn btn-outline-light px-4" data-bs-dismiss="modal">
                        No
                    </button>
                </div>

            </div>
        </div>
    </div>

    <!-- Modal de cancelar -->
    <div class="modal fade" id="cancelarTipoGastoModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content bg-dark text-white border-0 rounded-4">

                <div class="modal-header border-0">
                    <h5 class="modal-title text-danger">
                        <i class="fa-solid fa-triangle-exclamation me-2"></i>
                        Confirmar cancelación
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body text-center">
                    <p class="mb-0">¿Desea cancelar el registro?</p>
                    <small class="text-secondary">Se perderán los datos ingresados.</small>
                </div>

                <div class="modal-footer border-0 justify-content-center">

                    <button type="button"
                            class="btn btn-danger px-4"
                            data-bs-dismiss="modal"
                            onclick="cancelarTipoGasto()">
                        Sí, cancelar
                    </button>

                    <button type="button" class="btn btn-secondary px-4" data-bs-dismiss="modal">
                        No
                    </button>

                </div>

            </div>
        </div>
    </div>

    <!-- Scripts Confirmar y Cancelar -->
    <script>
        function confirmarTipoGasto() {

            var form = document.getElementById("tipoGastoForm");

            var modal = bootstrap.Modal.getInstance(document.getElementById('confirmarTipoGastoModal'));
            modal.hide();

            form.submit();
        }

        function cancelarTipoGasto() {

         document.getElementById("tipoGastoForm").reset();

        }
    </script>
    <!-- Listado de categorías -->
    <h2 class="text-white mt-5 mb-4">Categorías existentes</h2>
    <table class="table table-dark table-striped">
        <thead>
            <tr>
                <th>Nombre</th>
                <th>Precio</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Categorias)
            {
                <tr>
                    <td>@item.Categoria</td>
                    <td>@item.Precio</td>

                    <td>
                        <button class="btn btn-warning btn-sm" data-bs-toggle="modal" data-bs-target="#editarTipoModal"
                                data-id="@item.TipoGastoId">
                            <i class="fa fa-edit"></i> Editar
                        </button>



                        <form asp-controller="TiposGastos" asp-action="EliminarTipoGasto" asp-route-id="@item.TipoGastoId" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('¿Seguro que deseas eliminar esta categoría?');">
                                <i class="fa fa-trash"></i> Eliminar
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
<!-- Contenedor vacío del modal -->
<div class="modal fade" id="editarTipoModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <!-- Aquí se inyecta el partial _EditarTipoGastoModal.cshtml -->
        </div>
    </div>
</div>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        const modal = document.getElementById('editarTipoModal');

        // Cuando se abre el modal
        modal.addEventListener('show.bs.modal', function (event) {
            const button = event.relatedTarget; // botón que disparó el modal
            const id = button.getAttribute('data-id'); // id del tipo de gasto

            // Llamar al controlador para obtener la vista parcial
            fetch(`/TiposGastos/EditarTipoGasto/${id}`)
                .then(response => response.text())
                .then(html => {
                    // Insertar el contenido en el modal
                    modal.querySelector('.modal-content').innerHTML = html;
                });
        });
    });
</script>