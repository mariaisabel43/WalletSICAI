@model WalletSICAI.Models_.TiposGasto

<h2>Agregar nueva categoría</h2>

<div class="tab-content mt-3" id="gestionTabsContent">
    
    <div class="tab-pane fade show active" id="tipo" role="tabpanel" aria-labelledby="tipo-tab">
        <form asp-action="CrearTipoGasto" method="post">
            <div class="form-group">
                <label asp-for="Categoria">Nombre del Tipo de Gasto</label>
                <input asp-for="Categoria" class="form-control" />
                <span asp-validation-for="Categoria" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Precio">Precio</label>
                <input asp-for="Precio" type="number" class="form-control" />
                <span asp-validation-for="Precio" class="text-danger"></span>
            </div>

            <div class="form-group mt-3">
                <input type="submit" value="Registrar Tipo de Gasto" class="btn btn-success" />
            </div>
        </form>
    </div>
</div>
