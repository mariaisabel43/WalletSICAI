@model WalletSICAI.viewModels.TiposGastoViewModel

@{
    ViewData["Title"] = "Gestión de Tipos de Gasto";
    Layout = null;
}

<div class="container mt-5">

    <!-- Formulario de creación -->
    <h2 class="text-white mb-4">Registrar Tipo de Gasto</h2>
    <div class="recarga-container text-white p-4 rounded-4 mx-auto" style="max-width:600px;">
        <form asp-controller="TiposGastos" asp-action="CrearTipoGasto" method="post">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label asp-for="NuevoTipo.Categoria" class="form-label">Nombre</label>
                <input asp-for="NuevoTipo.Categoria" class="form-control text-white border-0" />
                <span asp-validation-for="NuevoTipo.Categoria" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="NuevoTipo.Precio" class="form-label">Precio</label>
                <input asp-for="NuevoTipo.Precio" type="number" class="form-control text-white border-0" />
                <span asp-validation-for="NuevoTipo.Precio" class="text-danger"></span>
            </div>

            <div class="mt-4 d-grid gap-2">
                <input type="submit" value="Registrar Tipo de Gasto" class="btn btn-success" />
            </div>
        </form>
    </div>

    <!-- Listado de categorías -->
    <h2 class="text-white mt-5 mb-4">Categorías existentes</h2>
    <table class="table table-dark table-striped">
        <thead>
            <tr>
                <th>Nombre</th>
                <th>Precio</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Categorias)
            {
                <tr>
                    <td>@item.Categoria</td>
                    <td>@item.Precio</td>

                    <td>
                        <button class="btn btn-warning btn-sm" data-bs-toggle="modal" data-bs-target="#editarTipoModal"
                                data-id="@item.TipoGastoId">
                            <i class="fa fa-edit"></i> Editar
                        </button>



                        <form asp-controller="TiposGastos" asp-action="EliminarTipoGasto" asp-route-id="@item.TipoGastoId" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('¿Seguro que deseas eliminar esta categoría?');">
                                <i class="fa fa-trash"></i> Eliminar
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
<!-- Contenedor vacío del modal -->
<div class="modal fade" id="editarTipoModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <!-- Aquí se inyecta el partial _EditarTipoGastoModal.cshtml -->
        </div>
    </div>
</div>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        const modal = document.getElementById('editarTipoModal');

        // Cuando se abre el modal
        modal.addEventListener('show.bs.modal', function (event) {
            const button = event.relatedTarget; // botón que disparó el modal
            const id = button.getAttribute('data-id'); // id del tipo de gasto

            // Llamar al controlador para obtener la vista parcial
            fetch(`/TiposGastos/EditarTipoGasto/${id}`)
                .then(response => response.text())
                .then(html => {
                    // Insertar el contenido en el modal
                    modal.querySelector('.modal-content').innerHTML = html;
                });
        });
    });
</script>

